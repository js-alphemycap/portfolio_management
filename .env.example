# Coindesk Market API
COINDESK_API_KEY=your_coindesk_key

# Symbols to ingest (comma separated); defaults provided via job YAML if omitted.
# SYMBOLS=BTC-USD,ETH-USD,SOL-USD,LINK-USD

# Historical granularity; currently supports "hours".
# GRANULARITY=hours
# Days of overlap when refreshing data.
# OVERLAP_DAYS=2

# Optional: override storage backend
# DB_URL=postgresql://price_data:price_data@localhost:5432/price_data
# DB_PATH=/absolute/path/to/data/databases/ohlcv.db

# Microsoft Graph Email Notifications
MS_TENANT_ID=
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_SENDER=
MS_RECIPIENT=

# Telegram bot (for sending dashboard summaries)
# Required by scripts/send_telegram_dashboard_summary.py
TELEGRAM_BOT_TOKEN=
